# Azure AD Configuration
AZURE_CLIENT_ID=your_client_id_here
AZURE_CLIENT_SECRET=your_client_secret_here
AZURE_TENANT_ID=your_tenant_id_here

# SharePoint Configuration (PROD)
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/your-site
SHAREPOINT_LIST_ID=your_list_id_here
SHAREPOINT_PLANILHA_RECEBIMENTOS=/Documentos/Recebimentos.xlsx

# OneDrive Personal Configuration (DEV)
ONEDRIVE_USER_PRINCIPAL_NAME=usuario@empresa.com.br

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your_secret_key_here

# Database Configuration
DATABASE_URL=sqlite:///receipt_db.db

# Application Configuration
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE=52428800
